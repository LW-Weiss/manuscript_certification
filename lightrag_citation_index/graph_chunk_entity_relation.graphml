  <data key="d0">Site-Directed Mutagenesis</data>
  <data key="d1">method</data>
  <data key="d2">A molecular biology technique used to make specific alterations to a DNA sequence, employed here to change amino acids in the VP2 region of IBDV.</data>
  <data key="d3">chunk-c8e2acc4aa0c45fe99be141430849f21</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768545977</data>
