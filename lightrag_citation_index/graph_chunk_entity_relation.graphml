<node id="Immunodiagnostic Techniques">
  <data key="d0">Immunodiagnostic Techniques</data>
  <data key="d1">method</data>
  <data key="d2">Immunodiagnostic techniques are a method characterized by high sensitivity, ease of performance, and serve as an excellent epidemiological tool for screening, surveillance, and control.</data>
  <data key="d3">chunk-6637a4ff732a42270c95a322eb3e4fc6</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768538575</data>
