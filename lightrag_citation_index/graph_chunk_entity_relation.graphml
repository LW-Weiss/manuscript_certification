<node id="Molecular Techniques">
  <data key="d0">Molecular Techniques</data>
  <data key="d1">method</data>
  <data key="d2">A category of diagnostic methods used in the pilot survey, including validated real-time PCR, to determine the prevalence and intensity of Schistosoma japonicum.</data>
  <data key="d3">chunk-c33d09b8957ec6de1ecb70a00240f29b</data>
