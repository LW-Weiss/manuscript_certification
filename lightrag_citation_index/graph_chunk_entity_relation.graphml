  <data key="d6"></data>
</node>
<node id="100 Eggs Per Gram Of Feces">
  <data key="d0">100 Eggs Per Gram Of Feces</data>
  <data key="d1">data</data>
  <data key="d2">This metric represents a threshold for low parasitic burden, specifically less than 100 eggs per gram of feces, below which 88.4% of the studied population excreted.</data>
  <data key="d3">chunk-f0d92923951ea02d5bee6d00bab160af</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768515106</data>
  <data key="d6"></data>
</node>
