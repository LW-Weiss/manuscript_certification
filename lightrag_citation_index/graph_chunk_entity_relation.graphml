</node>
<node id="Q253H">
  <data key="d0">Q253H</data>
  <data key="d1">concept</data>
  <data key="d2">A second specific amino acid alteration that, when combined with A284T, increased UK661's replication efficiency in tissue culture.</data>
  <data key="d3">chunk-c8e2acc4aa0c45fe99be141430849f21</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768545977</data>
