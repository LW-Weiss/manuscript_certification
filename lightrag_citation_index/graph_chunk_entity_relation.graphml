</node>
<node id="A284T">
  <data key="d0">A284T</data>
  <data key="d1">concept</data>
  <data key="d2">A specific amino acid alteration in the VP2 protein, which resulted in a limited capacity for UK661 to replicate in tissue culture.</data>
  <data key="d3">chunk-c8e2acc4aa0c45fe99be141430849f21</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768545977</data>
