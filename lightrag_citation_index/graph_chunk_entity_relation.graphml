<node id="UK661">
  <data key="d0">UK661</data>
  <data key="d1">creature</data>
  <data key="d2">A very virulent (vv) field strain of Infectious Bursal Disease Virus (IBDV) whose genomic segments were cloned and sequenced, and which induced morbidity and mortality in chickens.</data>
  <data key="d3">chunk-c8e2acc4aa0c45fe99be141430849f21</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768545977</data>
  <data key="d6"></data>
</node>
<node id="UK661rev">
  <data key="d0">UK661rev</data>
  <data key="d1">creature</data>
  <data key="d2">A strain of IBDV rescued from full-length cDNA copies of Genomic Segments A and B of UK661, which induced 100% morbidity and 50–80% mortality in chickens.</data>
  <data key="d3">chunk-c8e2acc4aa0c45fe99be141430849f21</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768545977</data>
  <data key="d6"></data>
