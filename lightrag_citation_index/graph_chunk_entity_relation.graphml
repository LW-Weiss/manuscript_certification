</node>
<node id="Novel Variant IBDV">
  <data key="d0">Novel Variant IBDV</data>
  <data key="d1">creature</data>
  <data key="d2">Novel Variant IBDV (nVarIBDV) is a strain of Infectious Bursal Disease Virus that has been widely prevalent in China since 2017, posing a new threat to the poultry industry.</data>
  <data key="d3">chunk-66b9c03397d1767f2c8fe38e229f4281</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1768506206</data>
  <data key="d6"></data>
</node>
