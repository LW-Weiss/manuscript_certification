  <data key="d1">concept</data>
  <data key="d2">Human infection refers to the state of humans being infected by Schistosoma japonicum, often through reservoir hosts.</data>
  <data key="d3">chunk-c33d09b8957ec6de1ecb70a00240f29b</data>
  <data key="d4">unknown_source</data>
